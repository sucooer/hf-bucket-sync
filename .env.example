# HuggingFace Access Token (Required)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Web Access Password
WEB_PASSWORD=hf123456

# Login session timeout (minutes, frontend)
VITE_AUTH_TIMEOUT_MINUTES=60

# Site title (frontend)
VITE_SITE_TITLE=HF Bucket Sync

# Local path for file browsing (default: current directory)
LOCAL_PATH=/home/hugging

# CDN base URL for file links in File Browser (frontend)
# Example: https://xxx.com
VITE_CDN_BASE_URL=https://xxx.com

# Login page background image (frontend)
# PC example: https://example.com/login-desktop.jpg
VITE_LOGIN_BG_PC=
# Mobile example: https://example.com/login-mobile.jpg
VITE_LOGIN_BG_MOBILE=
